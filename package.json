{
  "name": "notit-monorepo",
  "private": true,
  "workspaces": [
    "app",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w app",
    "build": "npm run build -w app",
    "check": "npm run check -w app",
    "preview": "npm run preview -w app",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "mcp:notit": "node packages/notit-mcp/server.js",
    "mobile:sync": "npm run build && cap sync",
    "ios": "npm run mobile:sync && cap open ios",
    "android": "npm run mobile:sync && cap open android",
    "desktop": ". \"$HOME/.cargo/env\" && cd platforms/desktop && ../../node_modules/.bin/tauri dev",
    "desktop:build": ". \"$HOME/.cargo/env\" && cd platforms/desktop && ../../node_modules/.bin/tauri build",
    "macos-distribute": "bash scripts/macos-distribute.sh"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@tauri-apps/api": "^2.11.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.3"
  }
}
