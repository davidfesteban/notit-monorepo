{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Notit",
  "version": "0.1.0",
  "identifier": "com.davidfesteban.notit",
  "build": {
    "frontendDist": "../../app/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../.. && npm run dev -w app -- --host 127.0.0.1",
    "beforeBuildCommand": "cd ../.. && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Notit",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
